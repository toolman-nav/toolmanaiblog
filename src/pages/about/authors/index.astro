---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { breadcrumbSchema } from "../../../lib/seo.mjs";

const title = "作者团队 - 工具人AI导航";
const description = "工具人AI导航作者与编辑团队说明。";
const structuredData = breadcrumbSchema([
  { name: "首页", url: "/" },
  { name: "关于我们", url: "/about/" },
  { name: "作者团队", url: "/about/authors/" },
]);
---

<SiteLayout activeNav="about" title={title} description={description} canonical="/about/authors/" structuredData={structuredData}>
  <section class="panel tutorial-detail" aria-labelledby="authorsTitle">
    <h1 id="authorsTitle">工具人AI导航作者团队</h1>
    <div class="detail-body markdown-body">
      <p>工具人AI导航团队负责整理 AI 工具评测、国内使用教程、订阅充值和海外数字服务相关内容。</p>
      <p>团队成员长期实测各类 AI 工具与海外数字服务，教程中的注册、订阅和支付流程均基于实际操作整理。</p>
      <p>由于各服务的价格、套餐和地区政策变化较快，我们会定期复查已发布内容，并在每篇文章标注更新时间，供读者判断信息时效。</p>
    </div>
  </section>
</SiteLayout>
