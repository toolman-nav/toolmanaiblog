---
import { getCollection } from "astro:content";
import site from "../data/site.mjs";
import SiteLayout from "../layouts/SiteLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import TutorialCard from "../components/TutorialCard.astro";
import { postsToArticles } from "../lib/posts.mjs";
import { blogDetailPath, toolDetailPath } from "../lib/routes.mjs";
import { collectionPageSchema, websiteSchema } from "../lib/seo.mjs";

const githubPosts = await getCollection("posts", ({ data }) => !data.draft);
const homeArticles = postsToArticles(githubPosts).slice(0, 8);
const popularTools = site.getPopularTools(8);
const githubTitleSmokeTest = "Claude Code国内使用指南";
const title = "工具人AI导航：AI 工具评测与国内使用教程";
const description = "工具人AI导航精选 AI 工具、实用教程和数字服务指南，帮助中文用户更快找到工具、学会方法、搭建工作流。";
const structuredData = [
  websiteSchema(),
  collectionPageSchema({
    name: "工具人AI导航推荐内容",
    description,
    path: "/",
    items: [
      ...homeArticles.map((article) => ({ name: article.title, url: blogDetailPath(article) })),
      ...popularTools.map((tool) => ({ name: tool.name, url: toolDetailPath(tool) })),
    ],
  }),
];
---

<SiteLayout activeNav="home" title={title} description={description} canonical="/" structuredData={structuredData}>
  <div class="home-layout">
    <section class="home-articles" aria-labelledby="homeArticlesTitle">
      <div class="section-head">
        <div>
          <h1 class="section-title">工具人AI导航：AI 工具评测与国内使用教程</h1>
          <h2 id="homeArticlesTitle" class="section-title section-subtitle">推荐文章</h2>
          <p class="section-copy">精选优质内容，掌握 AI 最新动态与实用技巧</p>
        </div>
        <a class="text-link" href="/blog/">查看全部文章 ›</a>
      </div>
      <div class="recommend-list">
        {homeArticles.map((article) => <TutorialCard article={article} compact />)}
      </div>
      <div class="load-more-row">
        <a class="load-more-button" href="/blog/">查看更多</a>
      </div>
    </section>

    <section class="home-tools" aria-labelledby="homeToolsTitle">
      <div class="section-head">
        <div>
          <h2 id="homeToolsTitle" class="section-title">推荐工具</h2>
          <p class="section-copy">先从这 8 个常用工具开始，提升效率与创造力</p>
        </div>
        <a class="text-link" href="/tools/">查看全部工具 ›</a>
      </div>
      <div class="tool-rail">
        {popularTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  </div>
</SiteLayout>
