---
import ArticleInfoPanel from "./ArticleInfoPanel.astro";
import ArticleVisual from "./ArticleVisual.astro";
import { tutorialDetailPath } from "../lib/routes.mjs";

const { article, compact = false } = Astro.props;
const className = compact ? "panel article-row" : "panel tutorial-card";
---

<a class={className} href={tutorialDetailPath(article)} data-tutorial-id={article.id}>
  {
    compact ? (
      <div class="thumb" data-cover={article.coverType}>
        {article.image ? <img src={article.image} alt={`${article.title} 封面`} loading="lazy" /> : <span class="visual-label">{article.title}</span>}
      </div>
    ) : (
      <ArticleVisual article={article} />
    )
  }
  <ArticleInfoPanel article={article} />
</a>
