---
import { toolDetailPath } from "../lib/routes.mjs";

const { tool } = Astro.props;
const searchText = [tool.name, tool.description, tool.category, tool.subcategory].join(" ");
---

<a
  class="panel tool-tile"
  href={toolDetailPath(tool)}
  data-tool-id={tool.id}
  data-search-text={searchText}
  aria-label={`查看 ${tool.name} 详情`}
>
  <div class="tile-icon" style={`--accent:${tool.accent}`}>{tool.iconText}</div>
  <div>
    <h3>{tool.name}</h3>
    <p>{tool.description}</p>
  </div>
</a>
