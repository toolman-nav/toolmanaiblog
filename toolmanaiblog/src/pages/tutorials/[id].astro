---
import { getCollection, render } from "astro:content";
import ArticleVisual from "../../components/ArticleVisual.astro";
import TutorialCard from "../../components/TutorialCard.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { postToArticle, postsToArticles } from "../../lib/posts.mjs";
import { tutorialDetailPath } from "../../lib/routes.mjs";
import { articleSchema } from "../../lib/seo.mjs";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { id: entry.id.replace(/\.md$/, "") },
    props: { entry, posts },
  }));
}

const { entry, posts } = Astro.props;
const article = postToArticle(entry, 0);
const { Content } = await render(entry);
const related = postsToArticles(posts).filter((item) => item.id !== article.id).slice(0, 3);
const structuredData = articleSchema({ ...article, url: tutorialDetailPath(article) });
---

<SiteLayout activeNav="tutorials" title={`${article.title} - 工具人AI导航`} description={article.summary} canonical={tutorialDetailPath(article)} image={article.image} pageType="article" structuredData={structuredData}>
  <section class="panel tutorial-detail" aria-labelledby="tutorialDetailTitle">
    <a class="detail-back" href="/tutorials/">‹ 返回教程列表</a>
    <div class="detail-hero">
      <ArticleVisual article={article} />
      <div>
        <span class="badge">{article.category}</span>
        <h1 id="tutorialDetailTitle">{article.title}</h1>
        <p>{article.summary}</p>
        <div class="meta-row">
          <span>工具人AI导航团队</span>
          <span>{article.date}</span>
          <span>{article.reads} 阅读</span>
        </div>
      </div>
    </div>
    <div class="detail-body markdown-body">
      <Content />
    </div>
    <div class="related-block">
      <div class="section-head">
        <h2 class="section-title">继续阅读</h2>
        <a class="text-link" href="/tutorials/">查看全部教程 ›</a>
      </div>
      <div class="related-grid">
        {related.map((item) => <TutorialCard article={item} />)}
      </div>
    </div>
  </section>
</SiteLayout>
